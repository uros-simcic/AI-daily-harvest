# copy to .env and fill in - .env is gitignored, never commit real values

# from https://console.mistral.ai -> API Keys
MISTRAL_API_KEY=your_mistral_api_key

# gmail account that sends the harvest
GMAIL_USER=sender@gmail.com

# 16-char app password from https://myaccount.google.com/apppasswords
# (requires 2-step verification; never the real account password)
GMAIL_APP_PASSWORD=your_app_password

# recipients, comma-separated. Sent via BCC so subscribers
# don't see each other's addresses. To add someone, just append
# their address here (and in the GMAIL_TO repo secret on GitHub).
GMAIL_TO=you@example.com,friend@example.com
